[global]
ioengine=libaio
fadvise_hint=0
invalidate=1
thread=1
openfiles=1
group_reporting=1
create_serialize=0
allrandrepeat=0
verify=0
time_based=1
runtime=20s
ramp_time=5s
file_service_type=random
fsync_on_close=1
overwrite=0
filename_format=$jobname.$jobnum.$filenum.size-${FILE_SIZE}

[test]
# --- Dynamic Parameters (Injected from CSV) ---
directory=${TEST_DATA_DIR}
rw=${IO_TYPE}
direct=${DIRECT}
iodepth=${IO_DEPTH}
numjobs=${THREADS}
filesize=${FILE_SIZE}
bs=${BS}
nrfiles=${NRFILES}
