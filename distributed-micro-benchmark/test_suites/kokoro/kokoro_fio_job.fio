[global]
ioengine=libaio
direct=${DIRECT}
verify=0
bs=$BS
iodepth=$IO_DEPTH
runtime=120s
ramp_time=30s
time_based=1
fadvise_hint=0
nrfiles=$NRFILES
thread=1
openfiles=1
group_reporting=1
filename_format=test.$jobnum.$filenum

[test]
rw=$IO_TYPE
filesize=$FILE_SIZE
directory=$TEST_DATA_DIR
numjobs=$THREADS
