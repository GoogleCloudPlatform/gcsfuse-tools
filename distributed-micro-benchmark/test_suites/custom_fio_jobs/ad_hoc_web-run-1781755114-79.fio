[global]
ioengine=libaio
fadvise_hint=0
fallocate=none
invalidate=1
thread=1
openfiles=1
group_reporting=1
create_serialize=0
allrandrepeat=0
file_service_type=random
rw=$IO_TYPE
iodepth=$IO_DEPTH
direct=$DIRECT
filename_format=$jobname.$jobnum.$filenum.size-${FILE_SIZE}

[seq_read]
directory=$TEST_DATA_DIR
bs=$BS
size=$FILE_SIZE
numjobs=$THREADS
nrfiles=1